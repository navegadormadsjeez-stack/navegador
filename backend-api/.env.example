# Database
DATABASE_URL="postgresql://madsjeez:madsjeez_secret@localhost:5432/madsjeez_browser?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# AI (OpenAI compatible)
AI_API_KEY=""
AI_API_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# Cloudflare R2 (updates)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="madsjeez-updates"
R2_PUBLIC_URL=""

# Admin
ADMIN_EMAIL="admin@madsjeez.com"

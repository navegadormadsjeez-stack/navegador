generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum AiRequestType {
  ML_TITLE
  SEO_DESCRIPTION
  CUSTOMER_REPLY
  COMPETITOR_ANALYSIS
  PAGE_SUMMARY
  FACEBOOK_POST
  PRICE_SUGGESTION
  GENERAL
}

enum UpdateChannel {
  STABLE
  BETA
}

enum NotificationType {
  INFO
  WARNING
  UPDATE
  ANNOUNCEMENT
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String
  isAdmin       Boolean        @default(false) @map("is_admin")
  isActive      Boolean        @default(true) @map("is_active")
  emailVerified Boolean        @default(false) @map("email_verified")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  subscription  Subscription?
  workspaces    Workspace[]
  products      Product[]
  aiRequests    AiRequest[]
  browserSettings BrowserSetting?
  sessions      Session[]
  notifications Notification[]
  favorites     Favorite[]
  telemetryEvents TelemetryEvent[]

  @@map("users")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique @map("user_id")
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  aiRequestsLimit  Int                @default(50) @map("ai_requests_limit")
  aiRequestsUsed   Int                @default(0) @map("ai_requests_used")
  resetAt          DateTime           @default(now()) @map("reset_at")
  expiresAt        DateTime?          @map("expires_at")
  stripeCustomerId String?            @map("stripe_customer_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Workspace {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  slug        String
  description String?
  color       String   @default("#6366f1")
  icon        String?
  isDefault   Boolean  @default(false) @map("is_default")
  startupUrls Json     @default("[]") @map("startup_urls")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites Favorite[]
  products  Product[]

  @@unique([userId, slug])
  @@map("workspaces")
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String?  @map("workspace_id")
  title       String
  url         String
  favicon     String?
  folder      String?
  createdAt   DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@map("favorites")
}

model Product {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  workspaceId    String?  @map("workspace_id")
  name           String
  sku            String?
  description    String?
  price          Decimal  @db.Decimal(12, 2)
  comparePrice   Decimal? @map("compare_price") @db.Decimal(12, 2)
  stock          Int      @default(0)
  images         Json     @default("[]")
  compatibilities Json    @default("[]")
  attributes     Json     @default("{}")
  tags           String[] @default([])
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("products")
}

model AiRequest {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  type        AiRequestType
  prompt      String
  response    String?
  pageUrl     String?       @map("page_url")
  tokensUsed  Int           @default(0) @map("tokens_used")
  durationMs  Int?          @map("duration_ms")
  createdAt   DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_requests")
}

model BrowserSetting {
  id            String  @id @default(cuid())
  userId        String  @unique @map("user_id")
  darkMode      Boolean @default(true) @map("dark_mode")
  sidebarOpen   Boolean @default(true) @map("sidebar_open")
  language      String  @default("es")
  searchEngine  String  @default("google") @map("search_engine")
  homePage      String  @default("https://www.madsjeez.com") @map("home_page")
  downloadPath  String? @map("download_path")
  preferences   Json    @default("{}")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("browser_settings")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?          @map("user_id")
  type      NotificationType @default(INFO)
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  isGlobal  Boolean          @default(false) @map("is_global")
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime?        @map("expires_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AppUpdate {
  id           String        @id @default(cuid())
  version      String        @unique
  channel      UpdateChannel @default(STABLE)
  title        String
  description  String
  downloadUrl  String        @map("download_url")
  checksum     String
  fileSize     BigInt        @map("file_size")
  isMandatory  Boolean       @default(false) @map("is_mandatory")
  minVersion   String?       @map("min_version")
  publishedAt  DateTime      @default(now()) @map("published_at")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("updates")
}

model TelemetryEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  eventType String   @map("event_type")
  payload   Json     @default("{}")
  appVersion String? @map("app_version")
  osVersion  String? @map("os_version")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@map("telemetry_events")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}

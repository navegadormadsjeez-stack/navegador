{
  "name": "madsjeez-seller-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Madsjeez Seller Browser - OS for online sellers",
  "scripts": {
    "dev:api": "npm run start:dev --prefix backend-api",
    "dev:admin": "npm run dev --prefix admin-panel",
    "dev:desktop": "dotnet run --project desktop-browser",
    "build:api": "npm run build --prefix backend-api",
    "build:admin": "npm run build --prefix admin-panel",
    "build:desktop": "dotnet build desktop-browser --configuration Release",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "npm run prisma:migrate --prefix backend-api",
    "db:seed": "npm run prisma:seed --prefix backend-api"
  }
}

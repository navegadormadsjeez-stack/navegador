<Window x:Class="MadsjeezSellerBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        xmlns:views="clr-namespace:MadsjeezSellerBrowser.Views"
        Title="Madsjeez Seller Browser"
        Height="900" Width="1440"
        MinHeight="640" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico"
        Background="{StaticResource BgPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="RightPanelColumn" Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="8,12,8,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,0,0,16">
                    <Image Source="/Assets/app-icon.png" Width="36" Height="36" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Madsjeez" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Browser" FontSize="10" Foreground="{StaticResource AccentCyanBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="NavHomeBtn" Style="{StaticResource SideNavButtonActive}" Click="NavHomeBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Inicio" Width="120"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavAiBtn" Style="{StaticResource SideNavButton}" Click="NavAiBtn_Click">
                        <TextBlock Text="IA Asistente"/>
                    </Button>
                    <Button x:Name="NavPublishBtn" Style="{StaticResource SideNavButton}" Click="ProductsBtn_Click">
                        <TextBlock Text="Publicar"/>
                    </Button>
                    <Button x:Name="NavToolsBtn" Style="{StaticResource SideNavButton}" Click="NavToolsBtn_Click">
                        <TextBlock Text="Herramientas"/>
                    </Button>
                    <Button x:Name="NavSocialBtn" Style="{StaticResource SideNavButton}" Click="NavSocialBtn_Click">
                        <TextBlock Text="Redes Sociales"/>
                    </Button>
                    <Button x:Name="NavDownloadsBtn" Style="{StaticResource SideNavButton}" Click="DownloadsBtn_Click">
                        <TextBlock Text="Descargas"/>
                    </Button>
                    <Button x:Name="NavBookmarksBtn" Style="{StaticResource SideNavButton}" Click="FavoritesBtn_Click">
                        <TextBlock Text="Marcadores"/>
                    </Button>
                    <Button x:Name="NavHistoryBtn" Style="{StaticResource SideNavButton}" Click="HistoryBtn_Click">
                        <TextBlock Text="Historial"/>
                    </Button>
                    <Button x:Name="NavExtensionsBtn" Style="{StaticResource SideNavButton}" Click="NavExtensionsBtn_Click">
                        <TextBlock Text="Extensiones"/>
                    </Button>
                    <Button x:Name="NavSettingsBtn" Style="{StaticResource SideNavButton}" Click="NavSettingsBtn_Click">
                        <TextBlock Text="Ajustes"/>
                    </Button>
                </StackPanel>

                <!-- Pro card -->
                <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Margin="4,12,4,8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Madsjeez Pro" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="IA ilimitada y perfiles avanzados" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                        <Button Content="Activar Ahora" Style="{StaticResource PrimaryButton}" FontSize="11"
                                Click="NavProBtn_Click"/>
                    </StackPanel>
                </Border>

                <ComboBox x:Name="ProfileComboBox" Grid.Row="3" Margin="4,0,4,8"
                          SelectionChanged="ProfileComboBox_SelectionChanged"
                          Background="#121A2E" Foreground="{StaticResource TextPrimaryBrush}"/>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="8,0">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SyncStatusText" Text="Sincronizado" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CENTER -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" Padding="8,8,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="TabBar" Orientation="Horizontal"/>
                    </ScrollViewer>
                    <Button Grid.Column="1" Content="+" Style="{StaticResource NavButton}" Width="36" Height="32"
                            ToolTip="Nueva pestaña" Click="NewTabBtn_Click" Margin="4,0,0,0"/>
                </Grid>
            </Border>

            <!-- Address bar -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}" Padding="12,8,12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BackBtn" Content="←" Style="{StaticResource NavButton}" Click="BackBtn_Click" ToolTip="Atrás"/>
                        <Button x:Name="ForwardBtn" Content="→" Style="{StaticResource NavButton}" Click="ForwardBtn_Click" ToolTip="Adelante"/>
                        <Button x:Name="ReloadBtn" Content="↻" Style="{StaticResource NavButton}" Click="ReloadBtn_Click" ToolTip="Recargar"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#0A0E1A" CornerRadius="22" BorderBrush="#253049"
                            BorderThickness="1" Margin="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="/Assets/app-icon.png" Width="20" Height="20" Margin="12,0,8,0"/>
                            <TextBox x:Name="UrlTextBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                     VerticalAlignment="Center" Padding="0,10"
                                     Tag="Buscar con Madsjeez o ingresar URL"
                                     KeyDown="UrlTextBox_KeyDown"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="BookmarkBtn" Content="☆" Style="{StaticResource NavButton}"
                                Click="BookmarkBtn_Click" ToolTip="Marcador"/>
                        <Button x:Name="HomeBtn" Content="Inicio" Style="{StaticResource NavButton}"
                                Click="HomeBtn_Click" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="2" Background="#000">
                <cef:ChromiumWebBrowser x:Name="WebBrowser"/>
                <views:NewTabPage x:Name="NewTabView" Visibility="Visible"/>
                <views:SettingsPage x:Name="SettingsView" Visibility="Collapsed"/>
                <Border x:Name="LoadingOverlay" Background="#80000000" Visibility="Collapsed">
                    <TextBlock Text="Cargando..." Foreground="White" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}" Padding="12,6"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RamStatusText" Text="RAM —" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                        <TextBlock x:Name="CpuStatusText" Text="CPU —" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                        <TextBlock x:Name="StatusText" Text="Listo" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Protección activa" FontSize="11" Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="VersionText" Text="v0.1.6" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT PANEL — AI -->
        <Border x:Name="AiSidebar" Grid.Column="2" Background="{StaticResource PanelGradientBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Asistente IA" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="¿En qué puedo ayudarte hoy?" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Quick tools -->
                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
                    <Button Content="Publicar" Style="{StaticResource QuickToolButton}" Margin="2" Click="ProductsBtn_Click"/>
                    <Button Content="Calc." Style="{StaticResource QuickToolButton}" Margin="2" Click="NavToolsBtn_Click"/>
                    <Button Content="Resumir" Style="{StaticResource QuickToolButton}" Margin="2" Click="AiAction_Summary"/>
                    <Button Content="Título ML" Style="{StaticResource QuickToolButton}" Margin="2" Click="AiAction_MlTitle"/>
                    <Button Content="SEO" Style="{StaticResource QuickToolButton}" Margin="2" Click="AiAction_SeoDescription"/>
                    <Button Content="Precio" Style="{StaticResource QuickToolButton}" Margin="2" Click="AiAction_Price"/>
                </UniformGrid>

                <ScrollViewer Grid.Row="2" MaxHeight="120" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <StackPanel>
                        <Button Content="Responder consulta" Style="{StaticResource AiActionButton}" Click="AiAction_CustomerReply"/>
                        <Button Content="Analizar competencia" Style="{StaticResource AiActionButton}" Click="AiAction_Competitor"/>
                        <Button Content="Post Facebook" Style="{StaticResource AiActionButton}" Click="AiAction_Facebook"/>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AiChatScroll" Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <StackPanel x:Name="AiChatPanel"/>
                </ScrollViewer>

                <TextBox x:Name="AiInput" Grid.Row="4" Style="{StaticResource UrlTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="80" MinHeight="36"
                         KeyDown="AiInput_KeyDown" Tag="Pregunta a Madsjeez AI..."/>

                <Button Grid.Row="5" Content="Enviar" Style="{StaticResource PrimaryButton}"
                        Margin="0,8,0,0" Click="AiSendBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

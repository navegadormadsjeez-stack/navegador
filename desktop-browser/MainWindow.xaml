<Window x:Class="MadsjeezSellerBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="Madsjeez Seller Browser"
        Height="900" Width="1440"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico"
        Background="{StaticResource BgPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="SidebarColumn" Width="360"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar / Profile Selector -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource BgSecondaryBrush}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Madsjeez Seller Browser" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                </StackPanel>

                <ComboBox x:Name="ProfileComboBox" Grid.Column="1"
                          Width="220" HorizontalAlignment="Center"
                          SelectionChanged="ProfileComboBox_SelectionChanged"
                          Background="#0f172a" Foreground="{StaticResource TextPrimaryBrush}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="ProductsBtn" Content="📦 Productos" Style="{StaticResource NavButton}"
                            Click="ProductsBtn_Click" Margin="4,0"/>
                    <Button x:Name="FavoritesBtn" Content="⭐ Favoritos" Style="{StaticResource NavButton}"
                            Click="FavoritesBtn_Click" Margin="4,0"/>
                    <Button x:Name="HistoryBtn" Content="🕐 Historial" Style="{StaticResource NavButton}"
                            Click="HistoryBtn_Click" Margin="4,0"/>
                    <Button x:Name="DownloadsBtn" Content="⬇ Descargas" Style="{StaticResource NavButton}"
                            Click="DownloadsBtn_Click" Margin="4,0"/>
                    <Button x:Name="ToggleSidebarBtn" Content="🤖 IA" Style="{StaticResource NavButton}"
                            Click="ToggleSidebarBtn_Click" Margin="4,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0f172a" Padding="4,4,4,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabBar" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- Navigation Bar -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource BgSecondaryBrush}" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BackBtn" Content="←" Style="{StaticResource NavButton}"
                            Click="BackBtn_Click" ToolTip="Atrás"/>
                    <Button x:Name="ForwardBtn" Content="→" Style="{StaticResource NavButton}"
                            Click="ForwardBtn_Click" ToolTip="Adelante"/>
                    <Button x:Name="ReloadBtn" Content="↻" Style="{StaticResource NavButton}"
                            Click="ReloadBtn_Click" ToolTip="Recargar"/>
                    <Button x:Name="HomeBtn" Content="🏠" Style="{StaticResource NavButton}"
                            Click="HomeBtn_Click" ToolTip="Inicio"/>
                </StackPanel>

                <TextBox x:Name="UrlTextBox" Grid.Column="1" Style="{StaticResource UrlTextBox}"
                         Margin="8,0" KeyDown="UrlTextBox_KeyDown"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BookmarkBtn" Content="☆" Style="{StaticResource NavButton}"
                            Click="BookmarkBtn_Click" ToolTip="Agregar favorito"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Browser Content -->
        <Grid Grid.Row="3" Grid.Column="0" Background="#000">
            <cef:ChromiumWebBrowser x:Name="WebBrowser"
                                    Address="https://www.madsjeez.com"/>
            <Border x:Name="LoadingOverlay" Background="#80000000"
                    Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Cargando..." Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0f172a" Padding="8,3">
            <Grid>
                <TextBlock x:Name="StatusText" Text="Listo"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                <TextBlock x:Name="VersionText" Text="v0.1.0 MVP"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- AI Sidebar -->
        <Border x:Name="AiSidebar" Grid.Row="1" Grid.RowSpan="4" Grid.Column="1"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="🤖 Madsjeez AI" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Asistente para vendedores" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" MaxHeight="200" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <StackPanel>
                        <Button Content="📝 Título Mercado Libre" Style="{StaticResource AiActionButton}"
                                Click="AiAction_MlTitle"/>
                        <Button Content="🔍 Descripción SEO" Style="{StaticResource AiActionButton}"
                                Click="AiAction_SeoDescription"/>
                        <Button Content="💬 Responder consulta" Style="{StaticResource AiActionButton}"
                                Click="AiAction_CustomerReply"/>
                        <Button Content="📊 Analizar competencia" Style="{StaticResource AiActionButton}"
                                Click="AiAction_Competitor"/>
                        <Button Content="📄 Resumir página" Style="{StaticResource AiActionButton}"
                                Click="AiAction_Summary"/>
                        <Button Content="📱 Post Facebook" Style="{StaticResource AiActionButton}"
                                Click="AiAction_Facebook"/>
                        <Button Content="💰 Sugerir precio" Style="{StaticResource AiActionButton}"
                                Click="AiAction_Price"/>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AiChatScroll" Grid.Row="2"
                              VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <StackPanel x:Name="AiChatPanel"/>
                </ScrollViewer>

                <TextBox x:Name="AiInput" Grid.Row="3"
                         Style="{StaticResource UrlTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MaxHeight="80" MinHeight="36"
                         KeyDown="AiInput_KeyDown"
                         Tag="Pregunta a Madsjeez AI..."/>

                <Button Grid.Row="4" Content="Enviar" Margin="0,8,0,0"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White" Padding="16,8"
                        BorderThickness="0" Cursor="Hand"
                        Click="AiSendBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

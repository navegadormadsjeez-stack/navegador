<Window x:Class="MadsjeezSellerBrowser.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Madsjeez Seller Browser - Iniciar sesión"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
            <TextBlock Text="⚡" FontSize="36" HorizontalAlignment="Center"/>
            <TextBlock Text="Madsjeez Seller Browser" FontSize="20" FontWeight="SemiBold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,4"/>
            <TextBlock Text="El OS para vendedores online" FontSize="12"
                       Foreground="#94a3b8" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel x:Name="LoginPanel" Grid.Row="1">
            <TextBlock Text="Email" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailBox" Padding="10" Background="#0f172a" Foreground="White"
                     BorderBrush="#334155" Margin="0,0,0,12"/>
            <TextBlock Text="Contraseña" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Padding="10" Background="#0f172a" Foreground="White"
                         BorderBrush="#334155" Margin="0,0,0,8"/>
            <TextBlock x:Name="ErrorText" Foreground="#f87171" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,8" Visibility="Collapsed"/>
            <Button x:Name="LoginBtn" Content="Iniciar sesión" Click="LoginBtn_Click"
                    Background="#6366f1" Foreground="White" Padding="12,8" BorderThickness="0"
                    Cursor="Hand" Margin="0,8,0,0"/>
            <Button x:Name="RegisterBtn" Content="Crear cuenta" Click="RegisterBtn_Click"
                    Background="Transparent" Foreground="#94a3b8" Padding="8" BorderThickness="0"
                    Cursor="Hand" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel x:Name="RegisterPanel" Grid.Row="1" Visibility="Collapsed">
            <TextBlock Text="Nombre" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Padding="10" Background="#0f172a" Foreground="White"
                     BorderBrush="#334155" Margin="0,0,0,12"/>
            <TextBlock Text="Email" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="RegEmailBox" Padding="10" Background="#0f172a" Foreground="White"
                     BorderBrush="#334155" Margin="0,0,0,12"/>
            <TextBlock Text="Contraseña" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="RegPasswordBox" Padding="10" Background="#0f172a" Foreground="White"
                         BorderBrush="#334155" Margin="0,0,0,8"/>
            <TextBlock x:Name="RegErrorText" Foreground="#f87171" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,8" Visibility="Collapsed"/>
            <Button x:Name="CreateAccountBtn" Content="Registrarse" Click="CreateAccountBtn_Click"
                    Background="#6366f1" Foreground="White" Padding="12,8" BorderThickness="0"
                    Cursor="Hand" Margin="0,8,0,0"/>
            <Button Content="← Volver al login" Click="BackToLogin_Click"
                    Background="Transparent" Foreground="#94a3b8" Padding="8" BorderThickness="0"
                    Cursor="Hand" Margin="0,4,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Demo: admin@madsjeez.com / Admin123!"
                   Foreground="#64748b" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,0"/>
    </Grid>
</Window>

<UserControl x:Class="MadsjeezSellerBrowser.Views.NewTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimaryBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24,32,32" MaxWidth="920" HorizontalAlignment="Center">

            <!-- Brand -->
            <StackPanel HorizontalAlignment="Center" Margin="0,8,0,28">
                <Image Source="/Assets/app-icon.png" Width="72" Height="72" Margin="0,0,0,12"/>
                <TextBlock Text="MADSJEEZ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                <TextBlock Text="BROWSER" FontSize="12" Foreground="{StaticResource AccentCyanBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Search -->
            <Border Style="{StaticResource GlassPanel}" Padding="4" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Buscar" FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                               Margin="16,0,8,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="15"
                             VerticalAlignment="Center" Padding="0,12"
                             Text="Buscar en la web de forma privada..."
                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"
                             KeyDown="SearchBox_KeyDown"/>
                    <Button Grid.Column="2" Content="IA" Style="{StaticResource NavButton}"
                            ToolTip="Asistente IA" Click="AiSearchBtn_Click" Margin="4"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                <Border Background="#121A2E" CornerRadius="12" Padding="10,4" Margin="4">
                    <TextBlock Text="Privado" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
                <Border Background="#121A2E" CornerRadius="12" Padding="10,4" Margin="4">
                    <TextBlock Text="Rápido" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
                <Border Background="#121A2E" CornerRadius="12" Padding="10,4" Margin="4">
                    <TextBlock Text="Inteligente" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
                <Border Background="#121A2E" CornerRadius="12" Padding="10,4" Margin="4">
                    <TextBlock Text="Tuyo" FontSize="11" Foreground="{StaticResource AccentPurpleBrush}"/>
                </Border>
            </StackPanel>

            <!-- Quick access -->
            <TextBlock Text="Acceso rápido" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
            <UniformGrid Columns="4" Margin="0,0,0,28">
                <Button Tag="https://www.google.com" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72">
                    <StackPanel>
                        <TextBlock Text="G" FontSize="20" FontWeight="Bold" Foreground="#4285F4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Google" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Tag="https://www.youtube.com" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72">
                    <StackPanel>
                        <TextBlock Text="&#x25B6;" FontSize="18" Foreground="#FF0000" HorizontalAlignment="Center"/>
                        <TextBlock Text="YouTube" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Tag="https://www.mercadolibre.com.ar" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72">
                    <StackPanel>
                        <TextBlock Text="ML" FontSize="16" FontWeight="Bold" Foreground="#FFE600" HorizontalAlignment="Center"/>
                        <TextBlock Text="MercadoLibre" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Tag="https://www.facebook.com" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72">
                    <StackPanel>
                        <TextBlock Text="f" FontSize="20" FontWeight="Bold" Foreground="#1877F2" HorizontalAlignment="Center"/>
                        <TextBlock Text="Facebook" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Tag="https://www.instagram.com" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72">
                    <StackPanel>
                        <TextBlock Text="IG" FontSize="14" FontWeight="Bold" Foreground="#E4405F" HorizontalAlignment="Center"/>
                        <TextBlock Text="Instagram" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Tag="https://web.whatsapp.com" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72">
                    <StackPanel>
                        <TextBlock Text="WA" FontSize="14" FontWeight="Bold" Foreground="#25D366" HorizontalAlignment="Center"/>
                        <TextBlock Text="WhatsApp" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Tag="about:newtab" Style="{StaticResource QuickToolButton}" Margin="4"
                        Click="QuickLink_Click" Height="72" ToolTip="Próximamente">
                    <StackPanel>
                        <TextBlock Text="+" FontSize="22" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Agregar" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Stats -->
            <TextBlock Text="Estadísticas de hoy" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
            <UniformGrid Columns="4">
                <Border Style="{StaticResource GlassPanel}" Margin="4" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Tiempo ahorrado" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="StatTimeText" Text="—" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassPanel}" Margin="4" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Rastreadores" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="StatTrackersText" Text="0" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentCyanBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassPanel}" Margin="4" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Anuncios" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="StatAdsText" Text="0" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentPurpleBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassPanel}" Margin="4" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Datos ahorrados" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="StatDataText" Text="0 MB" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

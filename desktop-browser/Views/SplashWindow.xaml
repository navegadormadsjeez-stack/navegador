<Window x:Class="MadsjeezSellerBrowser.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Madsjeez Seller Browser"
        Height="280" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Icon="Assets/app.ico"
        Background="#0D1220">
    <Border BorderBrush="#253049" BorderThickness="1" CornerRadius="16" Margin="1">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32">
            <Image Source="/Assets/app-icon.png" Width="56" Height="56" Margin="0,0,0,16"/>
            <TextBlock Text="Madsjeez Seller Browser" FontSize="18" FontWeight="SemiBold"
                       Foreground="#F1F5F9" HorizontalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Iniciando..."
                       FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"
                       Margin="0,10,0,16"/>
            <ProgressBar IsIndeterminate="True" Height="4" Width="220"
                         Foreground="#6366F1" Background="#1E293B" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>

<UserControl x:Class="MadsjeezSellerBrowser.Views.ExtensionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimaryBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24,32,32" MaxWidth="820" HorizontalAlignment="Center">
            <StackPanel Margin="0,8,0,24">
                <TextBlock Text="Extensiones y herramientas" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Madsjeez usa Chromium embebido para mayor estabilidad. Chrome Web Store no está disponible en esta versión, pero estas funciones reemplazan las extensiones más usadas por vendedores."
                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>

            <Border Style="{StaticResource GlassPanel}" Padding="18" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Estado" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Las extensiones externas de Chrome todavía no están habilitadas. Para evitar fallos, bloqueos y problemas con sesiones de marketplace, por ahora Madsjeez ofrece herramientas integradas dentro del navegador."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2" Margin="0,0,0,18">
                <Button Tag="ai" Style="{StaticResource QuickToolButton}" Height="110" Margin="4"
                        Click="Tool_Click">
                    <StackPanel>
                        <TextBlock Text="IA Asistente" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Respuestas, títulos, SEO y análisis de competencia."
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Button>

                <Button Tag="publish" Style="{StaticResource QuickToolButton}" Height="110" Margin="4"
                        Click="Tool_Click">
                    <StackPanel>
                        <TextBlock Text="Publicar" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Panel de productos para organizar ventas y stock."
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Button>

                <Button Tag="tools" Style="{StaticResource QuickToolButton}" Height="110" Margin="4"
                        Click="Tool_Click">
                    <StackPanel>
                        <TextBlock Text="Herramientas" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Calculadora, utilidades y flujos rápidos de vendedor."
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Button>

                <Button Tag="updates" Style="{StaticResource QuickToolButton}" Height="110" Margin="4"
                        Click="Tool_Click">
                    <StackPanel>
                        <TextBlock Text="Actualizar" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Buscar nuevas versiones e instalar el navegador actualizado."
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Border Style="{StaticResource GlassPanel}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Próximamente" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Soporte para módulos propios de Madsjeez: plantillas, automatizaciones y conectores seguros para marketplaces."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
